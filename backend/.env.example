PORT=5000

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/vetcare"

JWT_SECRET=your_jwt_secret

# Email — all sends go through an HTTP API (works on hosts that block SMTP,
# e.g. Railway). Set ONE of the two keys below. Precedence: SendGrid, then
# Resend, then the SMTP fallback (local dev only).
#
# SENDGRID_API_KEY — the option that needs NO domain: verify a single sender
#   email in SendGrid (Settings > Sender Authentication > Single Sender) and
#   you can send to any recipient. Set MAIL_FROM to that verified address.
SENDGRID_API_KEY=
#
# RESEND_API_KEY — needs a verified domain to email arbitrary recipients;
#   without one it only delivers to your own Resend account address.
RESEND_API_KEY=

# The sender address. MUST match a verified sender for whichever provider is
# active. With SendGrid single-sender, use your verified email, e.g.:
MAIL_FROM="VetCare <your_verified_sender@gmail.com>"

# SMTP fallback (used only when neither API key is set — local dev).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Comma-separated list of frontend origins allowed to call this API in
# production, e.g. "https://vetcare.vercel.app". Not needed for localhost.
ALLOWED_ORIGINS=

# Base URL of the deployed frontend, used to build password-reset links
# sent by email, e.g. "https://vetcare.vercel.app" (no trailing slash).
FRONTEND_URL=http://localhost:5173