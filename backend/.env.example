PORT=5000

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/vetcare"

JWT_SECRET=your_jwt_secret

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="VetCare <your_email@gmail.com>"

# Comma-separated list of frontend origins allowed to call this API in
# production, e.g. "https://vetcare.vercel.app". Not needed for localhost.
ALLOWED_ORIGINS=

# Base URL of the deployed frontend, used to build password-reset links
# sent by email, e.g. "https://vetcare.vercel.app" (no trailing slash).
FRONTEND_URL=http://localhost:5173