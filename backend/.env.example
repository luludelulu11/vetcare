PORT=5000

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/vetcare"

JWT_SECRET=your_jwt_secret

# Email. Preferred: Resend (HTTP API, works on hosts that block SMTP such as
# Railway). Set RESEND_API_KEY and the app sends via Resend; leave it unset to
# fall back to the SMTP (MAIL_*) settings below for local dev.
RESEND_API_KEY=

# MAIL_FROM is used by both providers. With Resend, use a verified domain
# sender (e.g. "VetCare <noreply@yourdomain.com>"); for quick testing Resend
# also allows "VetCare <onboarding@resend.dev>" (delivers only to your own
# account email).
MAIL_FROM="VetCare <onboarding@resend.dev>"

# SMTP fallback (used only when RESEND_API_KEY is empty).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Comma-separated list of frontend origins allowed to call this API in
# production, e.g. "https://vetcare.vercel.app". Not needed for localhost.
ALLOWED_ORIGINS=

# Base URL of the deployed frontend, used to build password-reset links
# sent by email, e.g. "https://vetcare.vercel.app" (no trailing slash).
FRONTEND_URL=http://localhost:5173